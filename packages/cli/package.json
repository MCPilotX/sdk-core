{
  "name": "@intentorch/cli",
  "version": "0.8.0",
  "description": "CLI tool for IntentOrch - MCP Ecosystem Orchestration Platform",
  "main": "dist/index.js",
  "bin": {
    "intorch": "./bin/intorch.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "orchestration",
    "cli",
    "command-line",
    "tools"
  ],
  "author": "MCPilotX",
  "license": "Apache 2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpilotx/intentorch.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/mcpilotx/intentorch/issues"
  },
  "homepage": "https://github.com/mcpilotx/intentorch#readme",
  "dependencies": {
    "@intentorch/core": "workspace:*",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}