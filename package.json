{
  "name": "@intentorch/workspace",
  "version": "0.8.0",
  "private": true,
  "description": "Monorepo workspace for IntentOrch - MCP Ecosystem Orchestration Platform",
  "packageManager": "pnpm@8.11.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "release": "changeset publish"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "orchestration",
    "cli",
    "ai",
    "workspace",
    "monorepo"
  ],
  "author": "MCPilotX",
  "license": "Apache 2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpilotx/intentorch.git"
  },
  "bugs": {
    "url": "https://github.com/mcpilotx/intentorch/issues"
  },
  "homepage": "https://github.com/mcpilotx/intentorch#readme",
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@turbo/gen": "^2.4.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}