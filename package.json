{
  "name": "@mcpilotx/sdk-core",
  "version": "0.4.0",
  "description": "Core SDK for MCP service orchestration - Developer-focused, simple and elegant",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./daemon": {
      "import": "./dist/daemon/index.js",
      "require": "./dist/daemon/index.js",
      "types": "./dist/daemon/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --outDir dist --project tsconfig.json && node scripts/import-extensions.js",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build",
    "postbuild": "node scripts/import-extensions.js"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "dotenv": "^17.3.1",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^1.19.12",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "hono": "^4.12.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "orchestration",
    "sdk",
    "docker",
    "nodejs",
    "python",
    "go",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MCPilotX/sdk-core.git",
    "directory": "sdk-core"
  },
  "bugs": {
    "url": "https://github.com/MCPilotX/sdk-core/issues"
  },
  "homepage": "https://github.com/MCPilotX/sdk-core#readme",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "README.ZH_CN.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
