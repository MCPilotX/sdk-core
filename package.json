{
  "name": "@mcpilotx/intentorch",
  "version": "0.6.0",
  "type": "module",
  "description": "Intent-Driven MCP Orchestration Toolkit - Transform natural language into executable workflows with AI-powered intent parsing and MCP tool orchestration",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "intent",
    "orchestration",
    "ai",
    "workflow",
    "automation",
    "typescript",
    "sdk",
    "toolkit"
  ],
  "license": "Apache-2.0",
  "author": "MCPilotX",
  "homepage": "https://github.com/MCPilotX/IntentOrch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MCPilotX/IntentOrch.git"
  },
  "bugs": {
    "url": "https://github.com/MCPilotX/IntentOrch/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build/import-extensions.js",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "prepublishOnly": "npm run clean && npm run test && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dockerode": "^4.0.2",
    "dotenv": "^17.3.1",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^1.19.12",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "hono": "^4.12.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.24.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
